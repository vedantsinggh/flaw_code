# ForgeOS Configuration
# Copy this file to .env and fill in your values.

# ── Mode ───────────────────────────────────────────────────────────────────────
# true  = fully offline simulation (no LLM or API calls)
# false = live mode: Ollama for local models, Groq for cloud inference
SIMULATION_MODE=true

# ── Local LLM via Ollama ───────────────────────────────────────────────────────
# Required: have Ollama running with these models pulled:
#   ollama pull qwen2.5-coder:7b
#   ollama pull deepseek-r1:14b
OLLAMA_BASE_URL=http://localhost:11434

# ── Groq (cloud inference for heavy reasoning tasks) ──────────────────────────
# Free tier available at https://console.groq.com
# Used for Tier 3 tasks (complex architecture, high reasoning)
GROQ_API_KEY=gsk_your_groq_api_key_here

# ── Slack ─────────────────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token

# ── GitHub ────────────────────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_your_github_pat_here
GITHUB_REPOSITORY=owner/repository_name
