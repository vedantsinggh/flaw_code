# ForgeOS Configuration
# Copy this file to .env and fill in your values.

# ── Mode ───────────────────────────────────────────────────────────────────────
SIMULATION_MODE=false

# ── Local LLM via Ollama ───────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434

# ── Groq (cloud inference for heavy reasoning tasks) ──────────────────────────
GROQ_API_KEY=gsk_your_groq_api_key_here

# ── Slack Orchestration ────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_APP_TOKEN=xapp-your-slack-app-token
SLACK_SIGNING_SECRET=your_slack_signing_secret

# ── EastRouter Integration ────────────────────────────────────────────────────
EASTROUTER_API_KEY=your_eastrouter_api_key
EASTROUTER_BASE_URL=https://api.eastrouter.com/v1

# ── GitHub & Target Repository ────────────────────────────────────────────────
GITHUB_TOKEN=ghp_your_github_pat_here
GITHUB_REPOSITORY=owner/repository_name
TARGET_REPOSITORY=owner/repository_name
TARGET_BRANCH=main

# ── OpenClaw Workspace ────────────────────────────────────────────────────────
OPENCLAW_WORKSPACE=/home/mirage/Projects/forge2
